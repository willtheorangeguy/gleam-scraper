# Environment template for gleam-scraper
# Copy this to .env and fill in your values

# PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gleam_scraper
# or for Docker:
# DATABASE_URL=postgresql://user:password@db:5432/gleam_scraper

# Cache Configuration (in minutes)
CACHE_TTL=30

# Scraper Configuration
REQUEST_TIMEOUT=10
REQUEST_DELAY_SECONDS=1.0
MAX_RETRIES=3
# SCRAPER_MODE options: auto, requests, browser
SCRAPER_MODE=auto
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_WAIT_UNTIL=networkidle
PLAYWRIGHT_POST_NAV_WAIT_MS=750
PLAYWRIGHT_TIMEOUT_MULTIPLIER=4

# Environment
ENVIRONMENT=development
DEBUG=False
